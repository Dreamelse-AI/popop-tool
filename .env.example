# apimart 图像生成 API 密钥。复制此文件为 .env 并填入真实值。
# .env 已在 .gitignore 中，不会被提交。密钥只在 dev server 进程内使用，不进前端 bundle。
APIMART_API_KEY=sk-your-key-here

# 可选：apimart API 目标地址，默认 https://api.apimart.ai
APIMART_API_TARGET=https://api.apimart.ai

# 可选：上游代理。若本机直连 apimart 不通，填本机科学上网软件的 HTTP 代理端口。
# 例：Clash 默认 http://127.0.0.1:7890。不需要就留空或删掉这一行。
# 注：UPSTREAM_PROXY 仅 vite dev server 使用；生产 Express 服务端不读它
#（生产部署在能直连 apimart 的服务器上，无需代理）。
UPSTREAM_PROXY=

# 生产服务端访问口令（仅 server/ 生产服务端读取，vite dev server 不需要）。
# 用户带 ?token=<此值> 首次访问即种 cookie，之后免输；留空则不启用鉴权。
# 本地 pnpm dev 不经过此服务端，无需配置。
ACCESS_TOKEN=

# arca 海外后端域名（图库等接口）。dev 走 vite proxy /arca，生产走 Express /arca 反代。
# 默认 https://i18n-api.imaginewithu.com，按规范禁止硬编码在业务代码。
ARCA_ORIGIN=https://i18n-api.imaginewithu.com
